{
  "private": true,
  "name": "binarygrid",
  "version": "0.1.1",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "postinstall": "bun run build",
    "build": "vite build",
    "deploy": "bun run build && devvit upload",
    "dev": "devvit playtest",
    "preview": "vite preview",
    "login": "devvit login",
    "check": "svelte-check --tsconfig ./src/client/tsconfig.json",
    "launch": "bun run build && bun run deploy && devvit publish",
    "type-check": "tsc --build",
    "test": "vitest run",
    "local": "vite dev --port 7474"
  },
  "dependencies": {
    "@devvit/start": "^0.13.6",
    "@devvit/test": "^0.13.6",
    "@devvit/web": "0.13.6",
    "@hono/node-server": "^2.0.8",
    "@lucide/svelte": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "canvas-confetti": "^1.9.4",
    "devvit": "0.13.6",
    "hono": "^4.12.27",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "fast-check": "^4.8.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "vite": "8.1.3",
    "vitest": "^4.1.9"
  }
}