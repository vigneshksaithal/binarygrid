{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "binarygrid",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "inline": true,
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "asUser": [
        "SUBSCRIBE_TO_SUBREDDIT",
        "SUBMIT_COMMENT"
      ]
    }
  },
  "media": {
    "dir": "assets"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new Game",
        "description": "Binary Grid",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Create Weekly Recap",
        "description": "Post Binary Grid weekly recap",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-weekly-recap"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "daily-post-morning": {
        "endpoint": "/internal/schedule/daily",
        "cron": "0 8 * * *"
      },
      "daily-post-evening": {
        "endpoint": "/internal/schedule/daily",
        "cron": "0 20 * * *"
      },
      "weekly-recap": {
        "endpoint": "/internal/schedule/weekly-recap",
        "cron": "0 18 * * 0"
      },
      "refresh-preview": {
        "endpoint": "/internal/schedule/refresh-preview",
        "cron": "*/15 * * * *"
      }
    }
  },
  "dev": {
    "subreddit": "cat543"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
